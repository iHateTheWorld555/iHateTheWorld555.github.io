lass=\"ltx_toclist\">\n183\t<li class=\"ltx_tocentry ltx_tocentry_abstract\"><a href=\"#abstract1\" title=\"In Cover First, Disagree Softly: Rethinking Mismatch-First Active Learning for Frame-Level Audio Classification\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\">Abstract</span></a></li>\n184\t<li class=\"ltx_tocentry ltx_tocentry_section\"><a href=\"#S1\" title=\"In Cover First, Disagree Softly: Rethinking Mismatch-First Active Learning for Frame-Level Audio Classification\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\"><span class=\"ltx_tag ltx_tag_ref\">1 </span><span class=\"ltx_text ltx_font_smallcaps\">Introduction</span></span></a></li>\n185\t<li class=\"ltx_tocentry ltx_tocentry_section\">\n186\t<a href=\"#S2\" title=\"In Cover First, Disagree Softly: Rethinking Mismatch-First Active Learning for Frame-Level Audio Classification\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\"><span class=\"ltx_tag ltx_tag_ref\">2 </span><span class=\"ltx_text ltx_font_smallcaps\">Rethinking mismatch-first acquisition</span></span></a>\n187\t<ol class=\"ltx_toclist ltx_toclist_section\">\n188\t<li class=\"ltx_tocentry ltx_tocentry_subsection\"><a href=\"#S2.SS1\" title=\"In 2 Rethinking mismatch-first acquisition ‣ Cover First, Disagree Softly: Rethinking Mismatch-First Active Learning for Frame-Level Audio Classification\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\"><span class=\"ltx_tag ltx_tag_ref\">2.1 </span><span class=\"ltx_text ltx_font_italic\">Frame-level acquisition setup</span></span></a></li>\n189\t<li class=\"ltx_tocentry ltx_tocentry_subsection\"><a href=\"#S2.SS2\" title=\"In 2 Rethinking mismatch-first acquisition ‣ Cover First, Disagree Softly: Rethinking Mismatch-First Active Learning for Frame-Level Audio Classification\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\"><span class=\"ltx_tag ltx_tag_ref\">2.2 </span><span class=\"ltx_text ltx_font_italic\">MFFT: hard gating over a geometric backbone