;\n35\t    }\n36\t    // Pre-apply spinout-banner dismissal here, before the banner paints, so it\n37\t    // never flashes in only to be hidden later by the deferred arxiv-header.js.\n38\t    // Key matches arxiv-header.js: \"arxiv-banner-dismissed:\" + data-banner-name.\n39\t    if (localStorage.getItem('arxiv-banner-dismissed:spinout-nonprofit')) {\n40\t      document.documentElement.setAttribute(\"data-banner-dismissed\", \"\");\n41\t    }\n42\t  }\n43\t  // Run as soon as JS starts, to minimize repainting\n44\t  initializeReadingPreferences();\n45\t</script>\n46\t<link rel=\"apple-touch-icon\" sizes=\"180x180\"\n47\t  href=\"/static/browse/0.3.4/images/icons/apple-touch-icon.png\">\n48\t<link rel=\"icon\" type=\"image/png\" sizes=\"32x32\"\n49\t  href=\"/static/browse/0.3.4/images/icons/favicon-32x32.png\">\n50\t<link rel=\"icon\" type=\"image/png\" sizes=\"16x16\"\n51\t  href=\"/static/browse/0.3.4/images/icons/favicon-16x16.png\">\n52\t<link rel=\"manifest\" href=\"/static/browse/0.3.4/images/icons/site.webmanifest\">\n53\t<link rel=\"mask-icon\" href=\"/static/browse/0.3.4/images/icons/safari-pinned-tab.svg\" color=\"#5bbad5\">\n54\t<link rel=\"stylesheet\" type=\"text/css\" media=\"screen\" href=\"https://use.typekit.net/utz6mli.css\"><link rel=\"stylesheet\" type=\"text/css\" media=\"screen\"\n55\t  href=\"/static/base/1.0.1/css/arxiv-header-footer.css?v=20260626\"><style>\n56\t  /* Banner pre-dismissal (set above before paint -> no flash-then-hide) and\n57\t     reading-mode chrome hiding. */\n58\t  html[data-banner-dismissed] .ds-announcement { display: none; }\n59\t  html[data-reading-mode=\"enabled\"] .ds-announcement,\n60\t  html[data-reading-mode=\"enabled\"] .ds-site-footer { display: none; }\n61\t  /* Keep the announcement text dark on the Open-Blue band in both colour themes\n62\t     (otherwise it inherits the paper's warm-wash text in dark mode and washes out). */\n63\t  .ds-announcement-text { color: var(--arxiv-ink, #1c1a17); }\n64\t</style>\n