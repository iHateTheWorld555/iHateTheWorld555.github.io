">\n183\t<li class=\"ltx_tocentry ltx_tocentry_abstract\"><a href=\"#abstract1\" title=\"In Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\">Abstract</span></a></li>\n184\t<li class=\"ltx_tocentry ltx_tocentry_section\">\n185\t<a href=\"#S1\" title=\"In Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\"><span class=\"ltx_tag ltx_tag_ref\">1 </span>Introduction</span></a>\n186\t<ol class=\"ltx_toclist ltx_toclist_section\">\n187\t<li class=\"ltx_tocentry ltx_tocentry_paragraph\"><a href=\"#S1.SS0.SSS0.Px1\" title=\"In 1 Introduction ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\">Contributions.</span></a></li>\n188\t</ol>\n189\t</li>\n190\t<li class=\"ltx_tocentry ltx_tocentry_section\">\n191\t<a href=\"#S2\" title=\"In Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\"><span class=\"ltx_tag ltx_tag_ref\">2 </span>Related Work</span></a>\n192\t<ol class=\"ltx_toclist ltx_toclist_section\">\n193\t<li class=\"ltx_tocentry ltx_tocentry_paragraph\"><a href=\"#S2.SS0.SSS0.Px1\" title=\"In 2 Related Work ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\">ABAW and BAH.</span></a></li>\n194\t<li class=\"ltx_tocentry ltx_tocentry_paragraph\"><a href=\"#S2.SS0.SSS0.Px2\" title=\"In 2 Related Work ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\">Conflict fusion.</span></a></li>\n195\t<li class=\"ltx_tocentry ltx_tocentry_paragraph\"><a href=\"#S2.SS0.SSS0.Px3\" title=\"In 2 Related Work ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\">General vs. affect-specialised encoders.</span></a></li>\n196\t<li class=\"ltx_tocentry ltx_tocentry_paragraph\"><a href=\"#S2.SS0.SSS0.Px4\" title=\"In 2 Related Work ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\">Interpretable hesitation cues.</span></a></li>\n197\t<li class=\"ltx_tocentry ltx_tocentry_paragraph\"><a href=\"#S2.SS0.SSS0.Px5\" title=\"In 2 Related Work ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\">Calibration on small data.</span></a></li>\n198\t</ol>\n199\t</li>\n200\t<li class=\"ltx_tocentry ltx_tocentry_section\">\n201\t<a href=\"#S3\" title=\"In Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\"><span class=\"ltx_tag ltx_tag_ref\">3 </span>Method</span></a>\n202\t<ol class=\"ltx_toclist ltx_toclist_section\">\n203\t<li class=\"ltx_tocentry ltx_tocentry_subsection\"><a href=\"#S3.SS1\" title=\"In 3 Method ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\"><span class=\"ltx_tag ltx_tag_ref\">3.1 </span>Problem formulation</span></a></li>\n204\t<li class=\"ltx_tocentry ltx_tocentry_subsection\"><a href=\"#S3.SS2\" title=\"In 3 Method ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\"><span class=\"ltx_tag ltx_tag_ref\">3.2 </span>Modality encoders</span></a></li>\n205\t<li class=\"ltx_tocentry ltx_tocentry_subsection\"><a href=\"#S3.SS3\" title=\"In 3 Method ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\"><span class=\"ltx_tag ltx_tag_ref\">3.3 </span>Affective Marker Fusion (AMF)</span></a></li>\n206\t<li class=\"ltx_tocentry ltx_tocentry_subsection\"><a href=\"#S3.SS4\" title=\"In 3 Method ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\"><span class=\"ltx_tag ltx_tag_ref\">3.4 </span>ASR-erased time</span></a></li>\n207\t<li class=\"ltx_tocentry ltx_tocentry_subsection\"><a href=\"#S3.SS5\" title=\"In 3 Method ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\"><span class=\"ltx_tag ltx_tag_ref\">3.5 </span>Ensemble and calibration</span></a></li>\n208\t<li class=\"ltx_tocentry ltx_tocentry_subsection\"><a href=\"#S3.SS6\" title=\"In 3 Method ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\"><span class=\"ltx_tag ltx_tag_ref\">3.6 </span>Training on all labelled data</span></a></li>\n209\t</ol>\n210\t</li>\n211\t<li class=\"ltx_tocentry ltx_tocentry_section\">\n212\t<a href=\"#S4\" title=\"In Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\"><span class=\"ltx_tag ltx_tag_ref\">4 </span>Experiments</span></a>\n213\t<ol class=\"ltx_toclist ltx_toclist_section\">\n214\t<li class=\"ltx_tocentry ltx_tocentry_subsection\"><a href=\"#S4.SS1\" title=\"In 4 Experiments ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\"><span class=\"ltx_tag ltx_tag_ref\">4.1 </span>Dataset</span></a></li>\n215\t<li class=\"ltx_tocentry ltx_tocentry_subsection\"><a href=\"#S4.SS2\" title=\"In 4 Experiments ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\"><span class=\"ltx_tag ltx_tag_ref\">4.2 </span>Implementation details</span></a></li>\n216\t<li class=\"ltx_tocentry ltx_tocentry_subsection\"><a href=\"#S4.SS3\" title=\"In 4 Experiments ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\"><span class=\"ltx_tag ltx_tag_ref\">4.3 </span>Main results</span></a></li>\n217\t<li class=\"ltx_tocentry ltx_tocentry_subsection\"><a href=\"#S4.SS4\" title=\"In 4 Experiments ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\"><span class=\"ltx_tag ltx_tag_ref\">4.4 </span>Where the signal is?</span></a></li>\n218\t<li class=\"ltx_tocentry ltx_tocentry_subsection\"><a href=\"#S4.SS5\" title=\"In 4 Experiments ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\"><span class=\"ltx_tag ltx_tag_ref\">4.5 </span>Does conflict design help?</span></a></li>\n219\t<li class=\"ltx_tocentry ltx_tocentry_subsection\"><a href=\"#S4.SS6\" title=\"In 4 Experiments ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\"><span class=\"ltx_tag ltx_tag_ref\">4.6 </span>Calibration study</span></a></li>\n220\t<li class=\"ltx_tocentry ltx_tocentry_subsection\"><a href=\"#S4.SS7\" title=\"In 4 Experiments ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\"><span class=\"ltx_tag ltx_tag_ref\">4.7 </span>Members and ensemble</span></a></li>\n221\t<li class=\"ltx_tocentry ltx_tocentry_subsection\"><a href=\"#S4.SS8\" title=\"In 4 Experiments ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\"><span class=\"ltx_tag ltx_tag_ref\">4.8 </span>What did not help?</span></a></li>\n222\t</ol>\n223\t</li>\n224\t<li class=\"ltx_tocentry ltx_tocentry_section\">\n225\t<a href=\"#S5\" title=\"In Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\"><span class=\"ltx_tag ltx_tag_ref\">5 </span>Discussion</span></a>\n226\t<ol class=\"ltx_toclist ltx_toclist_section\">\n227\t<li class=\"ltx_tocentry ltx_tocentry_paragraph\"><a href=\"#S5.SS0.SSS0.Px1\" title=\"In 5 Discussion ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\">Why is the signal concentrated in text?</span></a></li>\n228\t<li class=\"ltx_tocentry ltx_tocentry_paragraph\"><a href=\"#S5.SS0.SSS0.Px2\" title=\"In 5 Discussion ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\">What we would do differently?</span></a></li>\n229\t<li class=\"ltx_tocentry ltx_tocentry_paragraph\"><a href=\"#S5.SS0.SSS0.Px3\" title=\"In 5 Discussion ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\">Limitations.</span></a></li>\n230\t</ol>\n231\t</li>\n232\t<li class=\"ltx_tocentry ltx_tocentry_section\"><a href=\"#S6\" title=\"In Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\"><span class=\"ltx_tag ltx_tag_ref\">6 </span>Conclusion</span></a></li>\n233\t<li class=\"ltx_tocentry ltx_tocentry_bibliography\"><a href=\"#bib\" title=\"In Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_title\">References</span></a></li>\n234\t</ol></nav>\n235\t</nav>\n236\t<div class=\"ltx_page_main\">\n237\t<div id=\"infobox\" class=\"infobox\">\n238\t  <a id=\"license-tr\" href=\"https://info.arxiv.org/help/license/index.html#licenses-available\">\n239\t    License: CC BY 4.0\n240\t  </a>\n241\t  <div id=\"watermark-tr\">\n242\tarXiv:2607.11120v1 [cs.CV] 13 Jul 2026</div>\n243\t</div><div class=\"ltx_page_content\">\n244\t<article class=\"ltx_document ltx_authors_1line\">\n245\t<h1 class=\"ltx_title ltx_title_document\">\n246\tSimple Features and Honest Calibration for\n247\t<br class=\"ltx_break\">Ambivalence and Hesitancy Recognition in Video\n248\t</h1>\n249\t<div class=\"ltx_authors\">\n250\t<span class=\"ltx_creator ltx_role_author\">\n251\t<span class=\"ltx_personname\">\n252\tVikas Kumar\n253\t<br class=\"ltx_break\">Indian Institute of Science Education and Research Bhopal, India\n254\t<br class=\"ltx_break\"><span id=\"id1.1.id1\" class=\"ltx_text ltx_font_typewriter\">vikas25@iiserb.ac.in</span>\n255\t</span></span>\n256\t<span class=\"ltx_author_before\">  </span><span class=\"ltx_creator ltx_role_author\">\n257\t<span class=\"ltx_personname\">Aditya Mishra\n258\t<br class=\"ltx_break\">Indian Institute of Science Education and Research Bhopal, India\n259\t<br class=\"ltx_break\"><span id=\"id2.1.id1\" class=\"ltx_text ltx_font_typewriter\">aditya21@iiserb.ac.in</span>\n260\t</span></span>\n261\t<span class=\"ltx_author_before\">  </span><span class=\"ltx_creator ltx_role_author\">\n262\t<span class=\"ltx_personname\">Haroon R. Lone\n263\t<br class=\"ltx_break\">Indian Institute of Science Education and Research Bhopal, India\n264\t<br class=\"ltx_break\"><span id=\"id3.1.id1\" class=\"ltx_text ltx_font_typewriter\">haroon@iiserb.ac.in</span>\n265\t</span></span>\n266\t</div>\n267\t\n268\t<div id=\"abstract1\" class=\"ltx_abstract\">\n269\t<h6 class=\"ltx_title ltx_title_abstract\">Abstract</h6>\n270\t<p class=\"ltx_p\">We address ambivalence and hesitancy (A/H) recognition in the ABAW 2026 BAH\n271\tChallenge: given a short interview video, predict whether the person shows signs\n272\tof A/H. Our system combines affect-specialised text, audio, and visual\n273\trepresentations with a small set of readable linguistic hesitation cues, fused by\n274\ta reliability gate we call Affective Marker Fusion (AMF), and finished with a\n275\tsimple AP-weighted ensemble at a fixed decision threshold. We also introduce\n276\t<em class=\"ltx_emph ltx_font_italic\">ASR-erased time</em>: speech recognisers delete fillers and hesitation pauses\n277\tfrom the transcript, but the chunk timestamps keep the time those events took, and\n278\tsixteen features built from these gaps form the strongest and most independent\n279\tnon-verbal channel we measured (AP <math class=\"ltx_Math\" alttext=\"0.718\" display=\"inline\" intent=\":literal\"><semantics><mn>0.718</mn><annotation encoding=\"application/x-tex\">0.718</annotation></semantics></math>, correlation <math class=\"ltx_Math\" alttext=\"0.11\" display=\"inline\" intent=\":literal\"><semantics><mn>0.11</mn><annotation encoding=\"application/x-tex\">0.11</annotation></semantics></math>–<math class=\"ltx_Math\" alttext=\"0.36\" display=\"inline\" intent=\":literal\"><semantics><mn>0.36</mn><annotation encoding=\"application/x-tex\">0.36</annotation></semantics></math> with all\n280\tother members). Across controlled experiments we find three things: cross-modal\n281\tconflict design does not reliably help on BAH; language is by far the strongest\n282\tchannel while affect-specialised audio is a useful second; and calibration matters\n283\tmore than architecture. Fitting ensemble weights and a threshold on the small validation split overfits: it scores <math class=\"ltx_Math\" alttext=\"0.741\" display=\"inline\" intent=\":literal\"><semantics><mn>0.741</mn><annotation encoding=\"application/x-tex\">0.741</annotation></semantics></math> macro-F1 on validation but only <math class=\"ltx_Math\" alttext=\"0.690\" display=\"inline\" intent=\":literal\"><semantics><mn>0.690</mn><annotation encoding=\"application/x-tex\">0.690</annotation></semantics></math> on the untouched test set. AP-weighting at a fixed threshold instead reaches <math class=\"ltx_Math\" alttext=\"\\mathbf{0.731}\" display=\"inline\" intent=\":literal\"><semantics><mn class=\"ltx_mathvariant_bold\" mathvariant=\"bold\">0.731</mn><annotation encoding=\"application/x-tex\">\\mathbf{0.731}</annotation></semantics></math> on test.\n284\tThe full pipeline is deterministic and runs from one script.<span class=\"ltx_note ltx_role_footnote\"><sup class=\"ltx_note_mark\">1</sup><span class=\"ltx_note_outer\"><span class=\"ltx_note_content\"><sup class=\"ltx_note_mark\">1</sup><span class=\"ltx_tag ltx_tag_note\">1</span>Code:\n285\t<a href=\"https://github.com/wmivikas/ABAW2026-Task2-ECCV\" title=\"\" class=\"ltx_ref ltx_url ltx_font_typewriter\">https://github.com/wmivikas/ABAW2026-Task2-ECCV</a>.</span></span></span></p>\n286\t</div>\n287\t<section id=\"S1\" class=\"ltx_section\">\n288\t<h2 class=\"ltx_title ltx_title_section\">\n289\t<span class=\"ltx_tag ltx_tag_section\">1 </span>Introduction</h2>\n290\t\n291\t<div id=\"S1.p1\" class=\"ltx_para\">\n292\t<p id=\"S1.p1.1\" class=\"ltx_p\">Ambivalence and hesitancy (A/H) are states of internal conflict: a person is unsure,\n293\tor pulled two ways at once. Detecting these moments in short answer videos is useful\n294\tfor behaviour-change tools, where a moment of hesitation is a good time to\n295\tintervene. The ABAW 2026 challenge frames this as a binary, video-level task on the\n296\tBAH dataset <cite class=\"ltx_cite ltx_citemacro_cite\">[<a href=\"#bib.bib1\" title=\"Bah dataset for ambivalence/hesitancy recognition in videos for behavioural change\" class=\"ltx_ref\">6</a>]</cite>, scored by macro-F1 (the unweighted mean of the\n297\tpresent- and absent-class F1) with average precision (AP) as a secondary measure.</p>\n298\t</div>\n299\t<div id=\"S1.p2\" class=\"ltx_para\">\n300\t<p id=\"S1.p2.1\" class=\"ltx_p\">A/H is widely treated as a <em id=\"S1.p2.1.1\" class=\"ltx_emph ltx_font_italic\">cross-modal conflict</em> problem, and the strongest\n301\tprior systems build hand-designed conflict features on top of three pre-trained\n302\tencoders <cite class=\"ltx_cite ltx_citemacro_cite\">[<a href=\"#bib.bib2\" title=\"Conflict-aware multimodal fusion for ambivalence and hesitancy recognition\" class=\"ltx_ref\">2</a>, <a href=\"#bib.bib3\" title=\"Hsemotion team at abaw-8 competition: audiovisual ambivalence/hesitancy, emotional mimicry intensity and facial expression recognition\" class=\"ltx_ref\">18</a>]</cite>. We reproduce that\n303\trecipe, test its central claim, and then ask a simpler question: where is the signal\n304\tactually? Three results organise the paper.</p>\n305\t</div>\n306\t<div id=\"S1.p3\" class=\"ltx_para\">\n307\t<ol id=\"S1.I1\" class=\"ltx_enumerate\">\n308\t<li id=\"S1.I1.i1\" class=\"ltx_item\" style=\"list-style-type:none;\">\n309\t<span class=\"ltx_tag ltx_tag_item\">1.</span> \n310\t<div id=\"S1.I1.i1.p1\" class=\"ltx_para\">\n311\t<p id=\"S1.I1.i1.p1.1\" class=\"ltx_p\"><span id=\"S1.I1.i1.p1.1.1\" class=\"ltx_text ltx_font_bold\">Conflict design is not the lever.</span> With encoders and training fixed,\n312\tswapping the conflict operator (absolute difference, orthogonal split, or none)\n313\tmoves public-test AP by at most <math id=\"S1.I1.i1.p1.1.m1\" class=\"ltx_Math\" alttext=\"0.05\" display=\"inline\" intent=\":literal\"><semantics><mn>0.05</mn><annotation encoding=\"application/x-tex\">0.05</annotation></semantics></math> and does not order the same way on validation\n314\tand test (Sec. <a href=\"#S4.SS5\" title=\"4.5 Does conflict design help? ‣ 4 Experiments ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_tag\">4.5</span></a>).</p>\n315\t</div>\n316\t</li>\n317\t<li id=\"S1.I1.i2\" class=\"ltx_item\" style=\"list-style-type:none;padding-top:2.0pt;\">\n318\t<span class=\"ltx_tag ltx_tag_item\">2.</span> \n319\t<div id=\"S1.I1.i2.p1\" class=\"ltx_para\">\n320\t<p id=\"S1.I1.i2.p1.5\" class=\"ltx_p\"><span id=\"S1.I1.i2.p1.5.1\" class=\"ltx_text ltx_font_bold\">Features help, but narrowly.</span> With general encoders the video and audio\n321\tchannels are near chance. An emotion-specialised audio encoder is a real gain; no\n322\tfacial representation we tried rescues the video channel (Sec. <a href=\"#S4.SS4\" title=\"4.4 Where the signal is? ‣ 4 Experiments ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_tag\">4.4</span></a>).\n323\t<span id=\"S1.I1.i2.p1.5.2\" class=\"ltx_text ltx_font_bold\">Calibration is the biggest gain.</span> On <math id=\"S1.I1.i2.p1.1.m1\" class=\"ltx_Math\" alttext=\"778\" display=\"inline\" intent=\":literal\"><semantics><mn>778</mn><annotation encoding=\"application/x-tex\">778</annotation></semantics></math> training videos, fitting ensemble weights and the decision threshold on the <math id=\"S1.I1.i2.p1.2.m2\" class=\"ltx_Math\" alttext=\"124\" display=\"inline\" intent=\":literal\"><semantics><mn>124</mn><annotation encoding=\"application/x-tex\">124</annotation></semantics></math>-video validation split scores <math id=\"S1.I1.i2.p1.3.m3\" class=\"ltx_Math\" alttext=\"0.741\" display=\"inline\" intent=\":literal\"><semantics><mn>0.741</mn><annotation encoding=\"application/x-tex\">0.741</annotation></semantics></math> there but only <math id=\"S1.I1.i2.p1.4.m4\" class=\"ltx_Math\" alttext=\"0.690\" display=\"inline\" intent=\":literal\"><semantics><mn>0.690</mn><annotation encoding=\"application/x-tex\">0.690</annotation></semantics></math> on test — the classic overfitting signature. Removing that search and using AP weights at a fixed threshold lifts public-test macro-F1 to <math id=\"S1.I1.i2.p1.5.m5\" class=\"ltx_Math\" alttext=\"0.731\" display=\"inline\" intent=\":literal\"><semantics><mn>0.731</mn><annotation encoding=\"application/x-tex\">0.731</annotation></semantics></math> (Sec. <a href=\"#S4.SS6\" title=\"4.6 Calibration study ‣ 4 Experiments ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_tag\">4.6</span></a>).</p>\n324\t</div>\n325\t</li>\n326\t</ol>\n327\t</div>\n328\t<section id=\"S1.SS0.SSS0.Px1\" class=\"ltx_paragraph\">\n329\t<h4 class=\"ltx_title ltx_title_paragraph\">Contributions.</h4>\n330\t\n331\t<div id=\"S1.SS0.SSS0.Px1.p1\" class=\"ltx_para\">\n332\t<ul id=\"S1.I2\" class=\"ltx_itemize\">\n333\t<li id=\"S1.I2.i1\" class=\"ltx_item\" style=\"list-style-type:none;\">\n334\t<span class=\"ltx_tag ltx_tag_item\">•</span> \n335\t<div id=\"S1.I2.i1.p1\" class=\"ltx_para\">\n336\t<p id=\"S1.I2.i1.p1.1\" class=\"ltx_p\"><span id=\"S1.I2.i1.p1.1.1\" class=\"ltx_text ltx_font_bold\">AMF</span>, a compact reliability-gated fusion of affect-specialised streams\n337\tand eleven interpretable hesitation markers.</p>\n338\t</div>\n339\t</li>\n340\t<li id=\"S1.I2.i2\" class=\"ltx_item\" style=\"list-style-type:none;padding-top:2.0pt;\">\n341\t<span class=\"ltx_tag ltx_tag_item\">•</span> \n342\t<div id=\"S1.I2.i2.p1\" class=\"ltx_para\">\n343\t<p id=\"S1.I2.i2.p1.1\" class=\"ltx_p\"><span id=\"S1.I2.i2.p1.1.1\" class=\"ltx_text ltx_font_bold\">ASR-erased time</span>, a new <math id=\"S1.I2.i2.p1.1.m1\" class=\"ltx_Math\" alttext=\"16\" display=\"inline\" intent=\":literal\"><semantics><mn>16</mn><annotation encoding=\"application/x-tex\">16</annotation></semantics></math>-dimensional signal recovered from ASR\n344\tchunk timestamps; it is the strongest non-verbal channel on BAH and nearly\n345\tuncorrelated with every model member.</p>\n346\t</div>\n347\t</li>\n348\t<li id=\"S1.I2.i3\" class=\"ltx_item\" style=\"list-style-type:none;padding-top:2.0pt;\">\n349\t<span class=\"ltx_tag ltx_tag_item\">•</span> \n350\t<div id=\"S1.I2.i3.p1\" class=\"ltx_para\">\n351\t<p id=\"S1.I2.i3.p1.1\" class=\"ltx_p\">A controlled study showing that conflict design does not help, that the signal\n352\tis concentrated in language, and that AP-weighted calibration at a fixed threshold\n353\tis the single largest source of improvement.</p>\n354\t</div>\n355\t</li>\n356\t<li id=\"S1.I2.i4\" class=\"ltx_item\" style=\"list-style-type:none;padding-top:2.0pt;\">\n357\t<span class=\"ltx_tag ltx_tag_item\">•</span> \n358\t<div id=\"S1.I2.i4.p1\" class=\"ltx_para\">\n359\t<p id=\"S1.I2.i4.p1.1\" class=\"ltx_p\">A deterministic, one-command pipeline that reaches <math id=\"S1.I2.i4.p1.1.m1\" class=\"ltx_Math\" alttext=\"0.731\" display=\"inline\" intent=\":literal\"><semantics><mn>0.731</mn><annotation encoding=\"application/x-tex\">0.731</annotation></semantics></math> macro-F1 on the\n360\tpublic test, above the previous edition’s winner.</p>\n361\t</div>\n362\t</li>\n363\t</ul>\n364\t</div>\n365\t<figure id=\"S1.F1\" class=\"ltx_figure\"><img src=\"2607.11120v1/figure/method_final.png\" id=\"S1.F1.g1\" class=\"ltx_graphics ltx_centering ltx_img_landscape\" width=\"479\" height=\"261\" alt=\"Refer to caption\">\n366\t<figcaption class=\"ltx_caption ltx_centering\"><span class=\"ltx_tag ltx_tag_figure\">Figure 1: </span>Overview. Text, video, and audio inputs are turned into affect-specialised\n367\tfeatures. AMF gates weak channels and predicts A/H. Six members are combined by\n368\tAP-weighted averaging at a fixed threshold of <math id=\"S1.F1.2.m1\" class=\"ltx_Math\" alttext=\"0.5\" display=\"inline\" intent=\":literal\"><semantics><mn>0.5</mn><annotation encoding=\"application/x-tex\">0.5</annotation></semantics></math>. Features that hurt the model\n369\t(gaze/brow dynamics, prosody, cue supervision) are excluded.</figcaption>\n370\t</figure>\n371\t</section>\n372\t</section>\n373\t<section id=\"S2\" class=\"ltx_section\">\n374\t<h2 class=\"ltx_title ltx_title_section\">\n375\t<span class=\"ltx_tag ltx_tag_section\">2 </span>Related Work</h2>\n376\t\n377\t<section id=\"S2.SS0.SSS0.Px1\" class=\"ltx_paragraph\">\n378\t<h4 class=\"ltx_title ltx_title_paragraph\">ABAW and BAH.</h4>\n379\t\n380\t<div id=\"S2.SS0.SSS0.Px1.p1\" class=\"ltx_para\">\n381\t<p id=\"S2.SS0.SSS0.Px1.p1.4\" class=\"ltx_p\">The ABAW series benchmarks multimodal affect in\n382\tvideo <cite class=\"ltx_cite ltx_citemacro_cite\">[<a href=\"#bib.bib4\" title=\"The 6th affective behavior analysis in-the-wild (abaw) competition\" class=\"ltx_ref\">10</a>]</cite>. BAH <cite class=\"ltx_cite ltx_citemacro_cite\">[<a href=\"#bib.bib1\" title=\"Bah dataset for ambivalence/hesitancy recognition in videos for behavioural change\" class=\"ltx_ref\">6</a>]</cite> adds whole-video A/H labels\n383\twith transcripts, aligned faces, and per-segment cue tags. The organisers’ zero-shot\n384\tLLM baseline reaches <math id=\"S2.SS0.SSS0.Px1.p1.1.m1\" class=\"ltx_Math\" alttext=\"0.283\" display=\"inline\" intent=\":literal\"><semantics><mn>0.283</mn><annotation encoding=\"application/x-tex\">0.283</annotation></semantics></math> macro-F1 and their co-attention baseline <math id=\"S2.SS0.SSS0.Px1.p1.2.m2\" class=\"ltx_Math\" alttext=\"0.59\" display=\"inline\" intent=\":literal\"><semantics><mn>0.59</mn><annotation encoding=\"application/x-tex\">0.59</annotation></semantics></math>; the\n385\tprevious edition’s winner reports <math id=\"S2.SS0.SSS0.Px1.p1.3.m3\" class=\"ltx_Math\" alttext=\"0.694\" display=\"inline\" intent=\":literal\"><semantics><mn>0.694</mn><annotation encoding=\"application/x-tex\">0.694</annotation></semantics></math> public / <math id=\"S2.SS0.SSS0.Px1.p1.4.m4\" class=\"ltx_Math\" alttext=\"0.715\" display=\"inline\" intent=\":literal\"><semantics><mn>0.715</mn><annotation encoding=\"application/x-tex\">0.715</annotation></semantics></math>\n386\tprivate <cite class=\"ltx_cite ltx_citemacro_cite\">[<a href=\"#bib.bib2\" title=\"Conflict-aware multimodal fusion for ambivalence and hesitancy recognition\" class=\"ltx_ref\">2</a>]</cite>.</p>\n387\t</div>\n388\t</section>\n389\t<section id=\"S2.SS0.SSS0.Px2\" class=\"ltx_paragraph\">\n390\t<h4 class=\"ltx_title ltx_title_paragraph\">Conflict fusion.</h4>\n391\t\n392\t<div id=\"S2.SS0.SSS0.Px2.p1\" class=\"ltx_para\">\n393\t<p id=\"S2.SS0.SSS0.Px2.p1.1\" class=\"ltx_p\">Prior A/H systems encode conflict as element-wise\n394\tabsolute differences between encoder features <cite class=\"ltx_cite ltx_citemacro_cite\">[<a href=\"#bib.bib2\" title=\"Conflict-aware multimodal fusion for ambivalence and hesitancy recognition\" class=\"ltx_ref\">2</a>]</cite>, echoing\n395\tdisagreement-aware fusion in multimodal sentiment analysis <cite class=\"ltx_cite ltx_citemacro_cite\">[<a href=\"#bib.bib20\" title=\"Context-dependent sentiment analysis in user-generated videos\" class=\"ltx_ref\">16</a>]</cite>\n396\tand cross-modal mismatch modelling in deception\n397\tdetection <cite class=\"ltx_cite ltx_citemacro_cite\">[<a href=\"#bib.bib21\" title=\"Verbal and nonverbal clues for real-life deception detection\" class=\"ltx_ref\">15</a>]</cite>. We ask whether this helps once the\n398\tencoders are fixed, and find it does not reliably help on BAH.</p>\n399\t</div>\n400\t</section>\n401\t<section id=\"S2.SS0.SSS0.Px3\" class=\"ltx_paragraph\">\n402\t<h4 class=\"ltx_title ltx_title_paragraph\">General vs. affect-specialised encoders.</h4>\n403\t\n404\t<div id=\"S2.SS0.SSS0.Px3.p1\" class=\"ltx_para\">\n405\t<p id=\"S2.SS0.SSS0.Px3.p1.1\" class=\"ltx_p\">Prior work uses VideoMAE,\n406\tpre-trained for actions <cite class=\"ltx_cite ltx_citemacro_cite\">[<a href=\"#bib.bib5\" title=\"Videomae: masked autoencoders are data-efficient learners for self-supervised video pre-training\" class=\"ltx_ref\">20</a>]</cite>, and HuBERT, general\n407\tspeech <cite class=\"ltx_cite ltx_citemacro_cite\">[<a href=\"#bib.bib6\" title=\"Hubert: self-supervised speech representation learning by masked prediction of hidden units\" class=\"ltx_ref\">9</a>]</cite>. Neither targets facial or vocal emotion. We substitute a\n408\tfacial-expression model and an emotion speech model <cite class=\"ltx_cite ltx_citemacro_cite\">[<a href=\"#bib.bib7\" title=\"Dawn of the transformer era in speech emotion recognition: closing the valence gap\" class=\"ltx_ref\">21</a>]</cite>; only the\n409\taudio substitution pays off. For text we use RoBERTa <cite class=\"ltx_cite ltx_citemacro_cite\">[<a href=\"#bib.bib11\" title=\"Roberta: a robustly optimized bert pretraining approach\" class=\"ltx_ref\">11</a>]</cite> fine-tuned on\n410\tGoEmotions <cite class=\"ltx_cite ltx_citemacro_cite\">[<a href=\"#bib.bib8\" title=\"GoEmotions: a dataset of fine-grained emotions\" class=\"ltx_ref\">3</a>]</cite>, whose emotion labels (confusion,\n411\tnervousness) fit hesitancy; a larger general model (DeBERTa-v3-large <cite class=\"ltx_cite ltx_citemacro_cite\">[<a href=\"#bib.bib14\" title=\"Deberta: decoding-enhanced bert with disentangled attention\" class=\"ltx_ref\">8</a>]</cite>)\n412\twas worse, so the right pre-training beats scale.</p>\n413\t</div>\n414\t</section>\n415\t<section id=\"S2.SS0.SSS0.Px4\" class=\"ltx_paragraph\">\n416\t<h4 class=\"ltx_title ltx_title_paragraph\">Interpretable hesitation cues.</h4>\n417\t\n418\t<div id=\"S2.SS0.SSS0.Px4.p1\" class=\"ltx_para\">\n419\t<p id=\"S2.SS0.SSS0.Px4.p1.1\" class=\"ltx_p\">Hesitancy has well-studied linguistic\n420\tcorrelates: hedges, filled pauses, self-repairs, contrastive markers. We compile\n421\tthese into a short, readable vector that rivals a fine-tuned language model.</p>\n422\t</div>\n423\t</section>\n424\t<section id=\"S2.SS0.SSS0.Px5\" class=\"ltx_paragraph\">\n425\t<h4 class=\"ltx_title ltx_title_paragraph\">Calibration on small data.</h4>\n426\t\n427\t<div id=\"S2.SS0.SSS0.Px5.p1\" class=\"ltx_para\">\n428\t<p id=\"S2.SS0.SSS0.Px5.p1.2\" class=\"ltx_p\">With <math id=\"S2.SS0.SSS0.Px5.p1.1.m1\" class=\"ltx_Math\" alttext=\"778\" display=\"inline\" intent=\":literal\"><semantics><mn>778</mn><annotation encoding=\"application/x-tex\">778</annotation></semantics></math> training videos the macro-F1\n429\tthreshold is high-variance; poor calibration is a known failure mode of modern\n430\tnetworks <cite class=\"ltx_cite ltx_citemacro_cite\">[<a href=\"#bib.bib22\" title=\"On calibration of modern neural networks\" class=\"ltx_ref\">7</a>]</cite>. We show that tuning the threshold on the\n431\t<math id=\"S2.SS0.SSS0.Px5.p1.2.m2\" class=\"ltx_Math\" alttext=\"124\" display=\"inline\" intent=\":literal\"><semantics><mn>124</mn><annotation encoding=\"application/x-tex\">124</annotation></semantics></math>-video validation split does not transfer, and instead fix it and weight members\n432\tby AP, which is threshold-free.</p>\n433\t</div>\n434\t</section>\n435\t</section>\n436\t<section id=\"S3\" class=\"ltx_section\">\n437\t<h2 class=\"ltx_title ltx_title_section\">\n438\t<span class=\"ltx_tag ltx_tag_section\">3 </span>Method</h2>\n439\t\n440\t<section id=\"S3.SS1\" class=\"ltx_subsection\">\n441\t<h3 class=\"ltx_title ltx_title_subsection\">\n442\t<span class=\"ltx_tag ltx_tag_subsection\">3.1 </span>Problem formulation</h3>\n443\t\n444\t<div id=\"S3.SS1.p1\" class=\"ltx_para\">\n445\t<p id=\"S3.SS1.p1.5\" class=\"ltx_p\">Each video <math id=\"S3.SS1.p1.1.m1\" class=\"ltx_Math\" alttext=\"x\" display=\"inline\" intent=\":literal\"><semantics><mi>x</mi><annotation encoding=\"application/x-tex\">x</annotation></semantics></math> has a binary label <math id=\"S3.SS1.p1.2.m2\" class=\"ltx_Math\" alttext=\"y\\in\\{0,1\\}\" display=\"inline\" intent=\":literal\"><semantics><mrow><mi>y</mi><mo>∈</mo><mrow><mo stretchy=\"false\">{</mo><mn>0</mn><mo>,</mo><mn>1</mn><mo stretchy=\"false\">}</mo></mrow></mrow><annotation encoding=\"application/x-tex\">y\\in\\{0,1\\}</annotation></semantics></math> and an elicitation question\n446\t<math id=\"S3.SS1.p1.3.m3\" class=\"ltx_Math\" alttext=\"q\\in\\{1,\\dots,7\\}\" display=\"inline\" intent=\":literal\"><semantics><mrow><mi>q</mi><mo>∈</mo><mrow><mo stretchy=\"false\">{</mo><mn>1</mn><mo>,</mo><mi mathvariant=\"normal\">…</mi><mo>,</mo><mn>7</mn><mo stretchy=\"false\">}</mo></mrow></mrow><annotation encoding=\"application/x-tex\">q\\in\\{1,\\dots,7\\}</annotation></semantics></math>. We predict a probability <math id=\"S3.SS1.p1.4.m4\" class=\"ltx_Math\" alttext=\"p(y{=}1\\mid x)\" display=\"inline\" intent=\":literal\"><semantics><mrow><mi>p</mi><mo lspace=\"0em\" rspace=\"0em\">​</mo><mrow><mo stretchy=\"false\">(</mo><mrow><mi>y</mi><mo>=</mo><mrow><mn>1</mn><mo>∣</mo><mi>x</mi></mrow></mrow><mo stretchy=\"false\">)</mo></mrow></mrow><annotation encoding=\"application/x-tex\">p(y{=}1\\mid x)</annotation></semantics></math> and are scored by\n447\t<math id=\"S3.SS1.p1.5.m5\" class=\"ltx_Math\" alttext=\"\\text{macro-F1}=\\tfrac{1}{2}(F_{1}^{(0)}+F_{1}^{(1)})\" display=\"inline\" intent=\":literal\"><semantics><mrow><mtext>macro-F1</mtext><mo>=</mo><mrow><mfrac><mn>1</mn><mn>2</mn></mfrac><mo lspace=\"0em\" rspace=\"0em\">​</mo><mrow><mo stretchy=\"false\">(</mo><mrow><msubsup><mi>F</mi><mn>1</mn><mrow><mo stretchy=\"false\">(</mo><mn>0</mn><mo stretchy=\"false\">)</mo></mrow></msubsup><mo>+</mo><msubsup><mi>F</mi><mn>1</mn><mrow><mo stretchy=\"false\">(</mo><mn>1</mn><mo stretchy=\"false\">)</mo></mrow></msubsup></mrow><mo stretchy=\"false\">)</mo></mrow></mrow></mrow><annotation encoding=\"application/x-tex\">\\text{macro-F1}=\\tfrac{1}{2}(F_{1}^{(0)}+F_{1}^{(1)})</annotation></semantics></math>, with positive-class AP as a\n448\tsecondary measure.</p>\n449\t</div>\n450\t</section>\n451\t<section id=\"S3.SS2\" class=\"ltx_subsection\">\n452\t<h3 class=\"ltx_title ltx_title_subsection\">\n453\t<span class=\"ltx_tag ltx_tag_subsection\">3.2 </span>Modality encoders</h3>\n454\t\n455\t<div id=\"S3.SS2.p1\" class=\"ltx_para\">\n456\t<p id=\"S3.SS2.p1.2\" class=\"ltx_p\">We use frozen affect-oriented encoders (Table <a href=\"#S3.T1\" title=\"Table 1 ‣ 3.2 Modality encoders ‣ 3 Method ‣ Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video\" class=\"ltx_ref\"><span class=\"ltx_text ltx_ref_tag\">1</span></a>). Text is the\n457\tRoBERTa-GoEmotions sentence embedding; video is a facial-expression ViT <cite class=\"ltx_cite ltx_citemacro_cite\">[<a href=\"#bib.bib13\" title=\"An image is worth 16x16 words: transformers for image recognition at scale\" class=\"ltx_ref\">4</a>]</cite>\n458\tover <math id=\"S3.SS2.p1.1.m1\" class=\"ltx_Math\" alttext=\"16\" display=\"inline\" intent=\":literal\"><semantics><mn>16</mn><annotation encoding=\"application/x-tex\">16</annotation></semantics></math> aligned face frames, giving an embedding and a <math id=\"S3.SS2.p1.2.m2\" class=\"ltx_Math\" alttext=\"7\" display=\"inline\" intent=\":literal\"><semantics><mn>7</mn><annotation encoding=\"application/x-tex\">7</annotation></semantics></math>-way expression profile\n459\t(mean and standard deviation); audio is an emotion-fine-tuned\n460\twav2vec2 <cite class=\"ltx_cite ltx_citemacro_cite\">[<a href=\"#bib.bib12\" title=\"Wav2vec 2.0: a framework for self-supervised learning of speech representations\" class=\"ltx_ref\">1</a>]</cite> model <cite class=\"ltx_cite ltx_citemacro_cite\">[<a href=\"#bib.bib7\" title=\"Dawn of the transformer era in speech emotion recognition: closing the valence gap\" class=\"ltx_ref\">21</a>]</cite>, mean-pooled over time. We additionally compute eleven interpretable text markers: rates of hedges,\n461\tfilled pauses, contrastive (“but”-type) words, negations, first-person uncertainty,\n462\trepeated words, and how much sentiment flips within the answer.</p>\n463\t</div>\n464\t<figure id=\"S3.T1\" class=\"ltx_table\">\n465\t<figcaption class=\"ltx_caption ltx_centering\" style=\"font-size:90%;\"><span class=\"ltx_tag ltx_tag_table\">Table 1: </span>Encoders. All are frozen; only lightweight heads are trained.</figcaption>\n466\t<table id=\"S3.T1.3\" class=\"ltx_tabular ltx_centering ltx_align_middle\">\n467\t<tbody class=\"ltx_tbody\">\n468\t<tr id=\"S3.T1.3.1.1\" class=\"ltx_tr\">\n469\t<td id=\"S3.T1.3.1.1.1\" class=\"ltx_td ltx_align_left ltx_border_tt\"><span id=\"S3.T1.3.1.1.1.1\" class=\"ltx_text\" style=\"font-size:90%;\">Stream</span></td>\n470\t<td id=\"S3.T1.3.1.1.2\" class=\"ltx_td ltx_align_left ltx_border_tt\"><span id=\"S3.T1.3.1.1.2.1\" class=\"ltx_text\" style=\"font-size:90%;\">Backbone</span></td>\n471\t<td id=\"S3.T1.3.1.1.3\" class=\"ltx_td ltx_align_center ltx_border_tt\"><span id=\"S3.T1.3.1.1.3.1\" class=\"ltx_text\" style=\"font-size:90%;\">Dim</span></td>\n472\t</tr>\n473\t<tr id=\"S3.T1.3.2.2\" class=\"ltx_tr\">\n474\t<td id=\"S3.T1.3.2.2.1\" class=\"ltx_td ltx_align_left ltx_border_t\"><span id=\"S3.T1.3.2.2.1.1\" class=\"ltx_text\" style=\"font-size:90%;\">Text</span></td>\n475\t<td id=\"S3.T1.3.2.2.2\" class=\"ltx_td ltx_align_left ltx_border_t\">\n476\t<span id=\"S3.T1.3.2.2.2.1\" class=\"ltx_text\" style=\"font-size:90%;\">RoBERTa-GoEmotions </span><cite class=\"ltx_cite ltx_citemacro_cite\"><span id=\"S3.T1.3.2.2.2.2.1\" class=\"ltx_text\" style=\"font-size:90%;\">[</span><a href=\"#bib.bib8\" title=\"GoEmotions: a dataset of fine-grained emotions\" class=\"ltx_ref\">3</a><span id=\"S3.T1.3.2.2.2.3.2\" class=\"ltx_text\" style=\"font-size:90%;\">]</span></cite>\n477\t</td>\n478\t<td id=\"S3.T1.3.2.2.3\" class=\"ltx_td ltx_align_center ltx_border_t\"><span id=\"S3.T1.3.2.2.3.1\" class=\"ltx_text\" style=\"font-size:90%;\">768</span></td>\n479\t</tr>\n480\t<tr id=\"S3.T1.3.3.3\" class=\"ltx_tr\">\n481\t<td id=\"S3.T1.3.3.3.1\" class=\"ltx_td ltx_align_left\"><span id=\"S3.T1.3.3.3.1.1\" class=\"ltx_text\" style=\"font-size:90%;\">Text markers</span></td>\n482\t<td id=\"S3.T1.3.3.3.2\" class=\"ltx_td ltx_align_left\"><span id=\"S3.T1.3.3.3.2.1\" class=\"ltx_text\" style=\"font-size:90%;\">hand-crafted hesitation cues</span></td>\n483\t<td id=\"S3.T1.3.3.3.3\" class=\"ltx_td ltx_align_center\"><span id=\"S3.T1.3.3.3.3.1\" class=\"ltx_text\" style=\"font-size:90%;\">11</span></td>\n484\t</tr>\n485\t<tr id=\"S3.T1.3.4.4\" class=\"ltx_tr\">\n486\t<td id=\"S3.T1.3.4.4.1\" class=\"ltx_td ltx_align_left\"><span id=\"S3.T1.3.4.4.1.1\" class=\"ltx_text\" style=\"font-size:90%;\">Video</span></td>\n487\t<td id=\"S3.T1.3.4.4.2\" class=\"ltx_td ltx_align_left\"><span id=\"S3.T1.3.4.4.2.1\" class=\"ltx_text\" style=\"font-size:90%;\">FER-ViT (facial expression)</span></td>\n488\t<td id=\"S3.T1.3.4.4.3\" class=\"ltx_td ltx_align_center\"><span id=\"S3.T1.3.4.4.3.1\" class=\"ltx_text\" style=\"font-size:90%;\">768 + 14</span></td>\n489\t</tr>\n490\t<tr id=\"S3.T1.3.5.5\" class=\"ltx_tr\">\n491\t<td id=\"S3.T1.3.5.5.1\" class=\"ltx_td ltx_align_left\"><span id=\"S3.T1.3.5.5.1.1\" class=\"ltx_text\" style=\"font-size:90%;\">Audio</span></td>\n492\t<td id=\"S3.T1.3.5.5.2\" class=\"ltx_td ltx_align_left\">\n493\t<span id=\"S3.T1.3.5.5.2.1\" class=\"ltx_text\" style=\"font-size:90%;\">emotion wav2vec2 </span><cite class=\"ltx_cite ltx_citemacro_cite\"><span id=\"S3.T1.3.5.5.2.2.1\" class=\"ltx_text\" style=\"font-size:90%;\">[</span><a href=\"#bib.bib7\" title=\"Dawn of the transformer era in speech emotion recognition: closing the valence gap\" class=\"ltx_ref\">21</a><span id=\"S3.T1.3.5.5.2.3.2\" class=\"ltx_text\" style=\"font-size:90%;\">]</span></cite>\n494\t</td>\n495\t<td id=\"S3.T1.3.5.5.3\" class=\"ltx_td ltx_align_center\"><span id=\"S3.T1.3.5.5.3.1\" class=\"ltx_text\" style=\"font-size:90%;\">1024</span></td>\n496\t</tr>\n497\t<tr id=\"S3.T1.3.6.6\" class=\"ltx_tr\">\n498\t<td id=\"S3.T1.3.6.6.1\" class=\"ltx_td ltx_align_left ltx_border_t\" colspan=\"3\"><em id=\"S3.T1.3.6.6.1.1\" class=\"ltx_emph ltx_font_italic\" style=\"font-size:90%;\">Encoder members (separate) also use:</em></td>\n499\t</tr>\n500\t<tr id=\"S3.T1.3.7.7\" class=\"ltx_tr\">\n501\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]}, "parent_tool_use_id": null, "session_id": "b1004a4d-e758-43e1-9f76-0588590cf162", "uuid": "a4be8000-c9ae-484c-846a-0f1a2222d6c9", "timestamp": "2026-07-14T05:50:30.491Z", "tool_use_result": {"type": "text", "file": {"filePath": "/inspire/qb-ilm/project/video-generation/chenxie-25019/hyr/iHateTheWorld555.github.io/.claude-review/projects/-inspire-qb-ilm-project-video-generation-chenxie-25019-hyr-iHateTheWorld555-github-io/b1004a4d-e758-43e1-9f76-0588590cf162/tool-results/br65wbdlq.txt", "content": "<!DOCTYPE html><html lang=\"en\">\n<head>\n<meta http-equiv=\"content-type\" content=\"text/html; charset=UTF-8\">\n<title>Simple Features and Honest Calibration for Ambivalence and Hesitancy Recognition in Video</title>\n<!--Generated on Mon Jul 13 05:43:51 2026 by LaTeXML (version 0.8.8) http://dlmf.nist.gov/LaTeXML/.-->\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, shrink-to-fit=no\">\n<link rel=\"stylesheet\" href=\"/static/browse/0.3.4/css/arxiv-html-papers-20260131.css\" type=\"text/css\">\n<script src=\"/static/browse/0.3.4/js/arxiv-html-papers-20260131.js\"></script>\n<script>\n  // Restore the saved color scheme preference, or\n  // enact the browser preference if \"automatic\", \n  // without expecting DOM load to have completed.\n  //\n  // Also restore any saved readingmode and ToC display preferences.\n  function initializeReadingPreferences() {\n    let saved_theme = localStorage.getItem(\"ar5iv_theme\") || \"automatic\";\n    if (saved_theme === \"automatic\") {\n      if (window.matchMedia(\"(prefers-color-scheme: dark)\").matc