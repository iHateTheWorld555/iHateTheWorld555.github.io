   <h3 class=\"browse-context-heading\">Current browse context:</h3>\n  <div class=\"current\">eess.AS</div>\n\n  <div class=\"prevnext\">\n<span class=\"arrow\">\n      <a class=\"abs-button prev-url\" href=\"/prevnext?id=2607.12807&amp;function=prev&amp;context=eess.AS\"\n         accesskey=\"p\" title=\"previous in eess.AS (accesskey p)\" rel=\"nofollow\">&lt;&nbsp;prev</a>\n    </span>\n    <span class=\"is-hidden-mobile\">&nbsp; | &nbsp;</span>    <span class=\"arrow\">\n      <a class=\"abs-button next-url\" href=\"/prevnext?id=2607.12807&amp;function=next&amp;context=eess.AS\" accesskey=\"n\"\n         title=\"next in eess.AS (accesskey n)\"  rel=\"nofollow\">next&nbsp;&gt;</a>\n    </span><br/>\n  </div><div class=\"list\">\n    <a class=\"abs-button abs-button-grey abs-button-small context-new\" href=\"/list/eess.AS/new\"  rel=\"nofollow\">new</a>\n    <span class=\"is-hidden-mobile\"> | </span>\n    <a class=\"abs-button abs-button-grey abs-button-small context-recent\" href=\"/list/eess.AS/recent\" rel=\"nofollow\">recent</a>\n    <span class=\"is-hidden-mobile\"> | </span><a class=\"abs-button abs-button-grey abs-button-small context-id\" href=\"/list/eess.AS/2026-07\" rel=\"nofollow\">2026-07</a>\n  </div><div class=\"abs-switch-cat\">\n    Change to browse by:\n    <div class=\"switch context-change\">", "stderr": "", "interrupted": false, "isImage": false, "noOutputExpected": false}}
